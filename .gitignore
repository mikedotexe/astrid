# Generated capsule workspace state
# Renamed consciousness-bridge → spectral-bridge (2026-06-08). Blanket-ignore the
# whole runtime workspace (5.1 GB / ~400k files) + the bridge.db/binary backups —
# never commit runtime state. (/target is already ignored globally above.)
capsules/spectral-bridge/workspace/
capsules/spectral-bridge/backups/

# Steward runtime state (top-level) + editor/build junk
/workspace/
.DS_Store
**/__pycache__/
*.pyc
capsules/perception/workspace/
capsules/perception/workspace/audio/
capsules/perception/workspace/perceptions/
capsules/perception/workspace/visual/
