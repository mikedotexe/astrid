<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.example.steward-control</string>
    <key>ProgramArguments</key>
    <array>
        <string>REPLACE_WITH_REPOSITORY/scripts/scheduler_examples/run_projection.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Minute</key>
            <integer>7</integer>
        </dict>
        <dict>
            <key>Minute</key>
            <integer>38</integer>
        </dict>
    </array>
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
